{
  "name": "@rizumu/nai",
  "type": "module",
  "version": "26.5.0",
  "packageManager": "pnpm@10.31.0",
  "description": "Interactive CLI for installing dependencies with catalog support",
  "author": "Rizumu <rizumu@ayaka.moe>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/LittleSound",
  "homepage": "https://github.com/LittleSound/nai#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LittleSound/nai.git"
  },
  "bugs": {
    "url": "https://github.com/LittleSound/nai/issues"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./cli": "./dist/cli.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.mts",
  "bin": {
    "nai": "./dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "lint": "eslint --cache .",
    "lint:fix": "pnpm run lint --fix",
    "build": "tsdown",
    "dev": "tsx src/cli.ts",
    "test": "vitest",
    "typecheck": "tsgo --noEmit",
    "format": "prettier --cache --write .",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@clack/prompts": "catalog:prod",
    "ansis": "catalog:prod",
    "cac": "catalog:prod",
    "fast-npm-meta": "catalog:prod",
    "yaml": "catalog:prod"
  },
  "devDependencies": {
    "@sxzz/eslint-config": "^7.8.3",
    "@sxzz/prettier-config": "^2.3.1",
    "@types/node": "^25.3.5",
    "@typescript/native-preview": "7.0.0-dev.20260309.1",
    "bumpp": "^10.4.1",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsdown": "catalog:dev",
    "tsdown-preset-sxzz": "^0.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "prettier": "@sxzz/prettier-config"
}
